{
  "name": "pakistan-property-hub-tests",
  "version": "1.0.0",
  "description": "Automated Testing Suite",
  "type": "module",
  "scripts": {
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --runInBand --forceExit --coverage --config tests/config/jest.config.js",
    "test:unit": "node --experimental-vm-modules node_modules/jest/bin/jest.js --runInBand --forceExit tests/unit --coverage --config tests/config/jest.config.js",
    "test:api": "node --experimental-vm-modules node_modules/jest/bin/jest.js --runInBand --forceExit tests/api --coverage --config tests/config/jest.config.js",
    "test:gui": "node --experimental-vm-modules node_modules/jest/bin/jest.js --runInBand --forceExit tests/gui --config tests/config/jest.config.js",
    "test:e2e": "node --experimental-vm-modules node_modules/jest/bin/jest.js --runInBand --forceExit tests/e2e --config tests/config/jest.config.js",
    "test:integration": "node --experimental-vm-modules node_modules/jest/bin/jest.js --runInBand --forceExit tests/integration --config tests/config/jest.config.js",
    "test:all": "npm run test:unit && npm run test:api && npm run test:integration",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch --config tests/config/jest.config.js",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --runInBand --forceExit --coverage --coverageReporters=html --config tests/config/jest.config.js",
    "test:ci": "node --experimental-vm-modules node_modules/jest/bin/jest.js --ci --runInBand --forceExit --coverage --maxWorkers=1 --config tests/config/jest.config.js"
  },
  "devDependencies": {
    "axios": "^1.5.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.0.0",
    "express-validator": "^7.0.0",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^7.5.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.6",
    "jest": "^29.7.0",
    "supertest": "^6.3.4",
    "selenium-webdriver": "^4.19.0",
    "mongodb-memory-server": "^9.1.6"
  }
}
